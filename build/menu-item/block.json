{
  "apiVersion": 3,
  "name": "mild-megamenu/menu-item",
  "category": "layout",
  "parent": [
    "mild-megamenu/menu"
  ],
  "attributes": {
    "url": {
      "type": "string",
      "default": ""
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "text": {
      "type": "string"
    },
    "linkTarget": {
      "type": "string"
    },
    "rel": {
      "type": "string"
    },
    "triggerType": {
      "type": "string",
      "default": "hover"
    },
    "dropdownAlignment": {
      "type": "string",
      "default": "center"
    },
    "dropdownTopOffset": {
      "type": "number",
      "default": 0
    }
  },
  "usesContext": [
    "mild-megamenu/showDropdownArrow"
  ],
  "supports": {
    "anchor": false,
    "align": false,
    "alignWide": false,
    "reusable": false,
    "color": {
      "link": true,
      "text": true,
      "background": true,
      "gradients": false,
      "duotone": false
    },
    "typography": {
      "fontSize": true,
      "__experimentalFontFamily": true,
      "fontFamily": true,
      "lineHeight": true,
      "letterSpacing": true,
      "fontStyle": true,
      "__experimentalFontWeight": true,
      "fontWeight": true
    },
    "lightBlockWrapper": false
  },
  "editorStyle": "file:./editor-style.css"
}