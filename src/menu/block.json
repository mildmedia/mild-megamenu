            "full"
        ],
        "color": {
            "link": true,
            "text": true,
            "background": true
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "letterSpacing": true,
            "__experimentalFontStyle": true,
            "fontStyle": true,
            "__experimentalFontWeight": true,
            "fontWeight": true,
            "__experimentalFontFamily": true,
            "__experimentalTextDecoration": true,
            "textDecoration": true,
            "fontFamily": true,
            "textTransform": true
        },
        "spacing": {
            "margin": true,
            "padding": true,
            "blockGap": true
        },
        "reusable": false,
        "customClassName": true,
        "lightBlockWrapper": false
