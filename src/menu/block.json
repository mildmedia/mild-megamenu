{
    "apiVersion": 3,
    "name": "mild-megamenu/menu",
    "title": "",
    "category": "layout",
    "attributes": {
        "itemsJustification": {
            "type": "string"
        },
        "expandDropdown": {
            "type": "boolean",
            "default": false
        },
        "collapseOnMobile": {
            "type": "boolean",
            "default": true
        },
        "responsiveBreakpoint": {
            "type": "number",
            "default": 600
        },
        "toggleButtonAlignment": {
            "type": "string"
        },
        "linkPaddingHorizontal": {
            "type": "number"
        },
        "linkPaddingVertical": {
            "type": "number"
        },
        "orientation": {
            "type": "string",
            "default": "horizontal"
        },
        "showDropdownArrow": {
            "type": "boolean",
            "default": true
        },
        "delayBetweenDropdowns": {
            "type": "number",
            "default": 0
        }
    },
    "providesContext": {
        "mild-megamenu/showDropdownArrow": "showDropdownArrow"
    },
    "supports": {
        "anchor": false,
        "align": [
